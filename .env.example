# Trading 212 API credentials - create these in the Trading 212 app/web account for the correct ISA account.
# Do not commit your real credentials.
TRADING212_API_KEY=
TRADING212_API_SECRET=
TRADING212_ENV=live  # live or demo

# Optional email settings if you later want automatic sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_EMAIL_TO=
REPORT_EMAIL_FROM=
